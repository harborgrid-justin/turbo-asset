# Mock Data Configuration Example
# These variables control the centralized mock data provider

# Asset Management
MOCK_ASSET_COUNT=100
MOCK_WORK_ORDER_COUNT=50

# Space Management  
MOCK_SPACE_COUNT=50
MOCK_MAINTENANCE_COUNT=200

# System Data
MOCK_AUDIT_ENTRY_COUNT=20
MOCK_TOTAL_COST=$487,650

# Business Intelligence
MOCK_BI_DEFAULT_RECORDS=100

# System Configuration
MOCK_ENABLE_RANDOMIZATION=true
MOCK_SEED=12345
MOCK_HEALTH_CHECK_INTERVAL=30000

# API Base Configuration
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Example: For development with smaller datasets
# MOCK_ASSET_COUNT=10
# MOCK_WORK_ORDER_COUNT=5
# MOCK_SPACE_COUNT=5

# Example: For testing with predictable data
# MOCK_ENABLE_RANDOMIZATION=false
# MOCK_SEED=12345