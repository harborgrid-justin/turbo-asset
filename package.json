{
  "name": "turbo-asset",
  "version": "1.0.0",
  "description": "Enterprise IBM Tririga Alternative - IWMS Platform",
  "main": "dist/index.js",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:napi": "npm run build --workspaces",
    "test:napi": "npm run test --workspaces",
    "build": "npm run clean && tsc",
    "build:watch": "tsc --watch",
    "clean": "rimraf dist",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "npx jest --passWithNoTests --config .development/jest.config.js",
    "test:watch": "npx jest --watch --config .development/jest.config.js",
    "test:coverage": "npx jest --coverage --config .development/jest.config.js",
    "test:comprehensive": "node .development/scripts/run-comprehensive-tests.js",
    "test:controllers": "node .development/scripts/run-comprehensive-tests.js --controllers",
    "test:services": "node .development/scripts/run-comprehensive-tests.js --services",
    "test:models": "node .development/scripts/run-comprehensive-tests.js --models",
    "test:generate": "node .development/scripts/generate-comprehensive-tests.js",
    "cypress:open": "npx cypress open --config-file .development/cypress.config.ts",
    "cypress:run": "npx cypress run --config-file .development/cypress.config.ts",
    "cypress:run:headless": "npx cypress run --headless --config-file .development/cypress.config.ts",
    "e2e": "start-server-and-test dev http://localhost:3000 cypress:run",
    "e2e:open": "start-server-and-test dev http://localhost:3000 cypress:open",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "quality": "npm run lint && npm run format:check && npm run type-check",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "docs:api": "swagger-jsdoc -d swaggerDef.js src/**/*.ts -o docs/api.json",
    "docs:generate": "typedoc src --out docs/code",
    "napi:generate": "node .development/scripts/generate-additional-napi-packages.js",
    "napi:health": "node .development/scripts/health-check.js",
    "napi:build:all": "npm run build:napi",
    "napi:test:all": "npm run test:napi",
    "integration:test": "npm run test -- tests/business-logic-integration.test.ts",
    "prepare": "husky install",
    "pre-commit": "lint-staged"
  },
  "keywords": [
    "iwms",
    "facilities-management",
    "real-estate",
    "enterprise",
    "tririga-alternative",
    "workflow-engine",
    "asset-management"
  ],
  "author": "HarborGrid",
  "license": "MIT",
  "dependencies": {
    "@apollo/server": "^4.9.5",
    "@graphql-tools/schema": "^10.0.0",
    "@prisma/client": "^5.6.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.12",
    "@types/uuid": "^10.0.0",
    "apollo-server-express": "^3.13.0",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csvtojson": "^2.0.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.1.0",
    "express-slow-down": "^3.0.0",
    "graphql": "^16.8.1",
    "graphql-upload": "^16.0.2",
    "helmet": "^7.2.0",
    "i18next": "^23.7.6",
    "i18next-fs-backend": "^2.3.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.0",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "redis": "^4.6.10",
    "socket.io": "^4.7.4",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/cypress": "^0.1.6",
    "@types/express": "^4.17.21",
    "@types/graphql-upload": "^17.0.0",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.12",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^2.0.16",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "cypress": "^15.0.0",
    "eslint": "^8.54.0",
    "husky": "^8.0.3",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.1.0",
    "prisma": "^5.6.0",
    "rimraf": "^5.0.5",
    "start-server-and-test": "^2.0.13",
    "supertest": "^6.3.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "ts-jest": "^29.1.1",
    "tsx": "^4.6.0",
    "typedoc": "^0.25.4",
    "typescript": "^5.3.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ],
    "*.{json,md}": [
      "prettier --write",
      "git add"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
