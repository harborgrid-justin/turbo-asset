  // Status tracking
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relationships
  lease           Lease           @relation(fields: [leaseId], references: [id])
  leaseId         String
  milestones      ContractMilestone[]
  vendors         ContractVendor[]

  @@map("lease_contracts")
}

// ASC 842/IFRS 16 Compliance Models
model LeaseAccounting {
  id              String            @id @default(uuid())
  accountingStandard AccountingStandard @default(ASC842)
  fiscalYear      Int
  fiscalPeriod    Int               // 1-12 for monthly, 1-4 for quarterly
  
  // ASC 842 / IFRS 16 calculations
  rightOfUseAsset Float?            // ROU asset value
  leaseLIABILITY  Float?            // lease liability
  
  // Present value calculations
  presentValue    Float?            // PV of lease payments
  discountRate    Float?            // incremental borrowing rate
  
  // Lease payments breakdown
  fixedPayments   Float?            // fixed lease payments
  variablePayments Float?           // variable lease payments
  residualValue   Float?            // guaranteed residual value
  
  // Amortization
  amortization    Float?            // periodic amortization
  interestExpense Float?            // periodic interest expense
  
  // Journal entry tracking
  debitAccount    String?           // chart of accounts
  creditAccount   String?           // chart of accounts
  journalAmount   Float?
  
  // Status
  status          AccountingStatus  @default(DRAFT)
  reviewedBy      String?
  reviewedAt      DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  
  // Metadata
  calculations    Json?             // detailed calculation data
  notes           String?
  
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  // Relationships
  lease           Lease             @relation(fields: [leaseId], references: [id])
  leaseId         String
  journalEntries  JournalEntry[]

  @@map("lease_accounting")
}

model JournalEntry {
  id              String        @id @default(uuid())
  entryNumber     String        @unique
  entryType       JournalType   @default(LEASE_LIABILITY)
  entryDate       DateTime      @default(now())
  postingDate     DateTime?
  
  // Entry details
  description     String
  reference       String?       // reference number
  totalDebit      Float
  totalCredit     Float
  
  // Integration
  externalId      String?       // ERP system ID
  syncStatus      IntegrationStatus @default(PENDING)
  lastSyncAt      DateTime?
  
  // Approval workflow
  status          JournalStatus @default(DRAFT)
  preparedBy      String?
  reviewedBy      String?
  approvedBy      String?
  postedBy        String?
  
  // Dates
  preparedAt      DateTime      @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  postedAt        DateTime?
  
  // Relationships
  leaseAccounting LeaseAccounting? @relation(fields: [leaseAccountingId], references: [id])
  leaseAccountingId String?
  lineItems       JournalLineItem[]
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("journal_entries")
}

model JournalLineItem {
  id              String        @id @default(uuid())
  lineNumber      Int
  accountCode     String        // chart of accounts
  accountName     String
  description     String?
  debitAmount     Float?
  creditAmount    Float?
  
  // Additional details
  costCenter      String?
  department      String?
  project         String?
  
  // Relationships
  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id])
  journalEntryId  String

  @@map("journal_line_items")
}

// Critical Date Tracking Models
model CriticalDate {
  id              String        @id @default(uuid())
  dateType        CriticalDateType
  dateValue       DateTime
  description     String
  importance      DateImportance @default(MEDIUM)
  
  // Alert settings
  alertDays       Json          // days before to alert (e.g., [90, 60, 30, 7])
  alertSent       Json?         // tracking which alerts were sent
  escalationRules Json?         // escalation workflow rules
  
  // Status
  isCompleted     Boolean       @default(false)
  completedAt     DateTime?
  completedBy     String?
  
  // Notifications
  reminderSent    Boolean       @default(false)
  lastReminderAt  DateTime?
  
  // Notes
  notes           String?
  actionRequired  String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  lease           Lease?        @relation(fields: [leaseId], references: [id])
  leaseId         String?
  contract        LeaseContract? @relation(fields: [contractId], references: [id])
  contractId      String?
  
  alerts          DateAlert[]

  @@map("critical_dates")
}

model DateAlert {
  id              String        @id @default(uuid())
  alertType       AlertType     @default(REMINDER)
  alertDate       DateTime      @default(now())
  scheduledFor    DateTime
  
  // Alert details
  title           String
  message         String
  priority        AlertPriority @default(MEDIUM)
  
  // Recipients
  recipients      Json          // array of user IDs, emails, or roles
  channels        Json          // email, sms, dashboard, etc.
  
  // Status
  status          AlertStatus   @default(PENDING)
  sentAt          DateTime?
  acknowledgedAt  DateTime?
  acknowledgedBy  String?
  
  // Escalation
  escalationLevel Int           @default(0)
  escalatedAt     DateTime?
  maxEscalation   Int           @default(3)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  criticalDate    CriticalDate  @relation(fields: [criticalDateId], references: [id])
  criticalDateId  String

  @@map("date_alerts")
}

// CAM Reconciliation Models
model CAMReconciliation {
  id              String          @id @default(uuid())
  reconciliationPeriod String      // YYYY format for annual, YYYY-MM for monthly
  reconciliationType CAMType      @default(ANNUAL)
  status          ReconciliationStatus @default(DRAFT)
  
  // CAM details
  totalCAMCharges Float           // total common area maintenance charges
  budgetedCAM     Float           // budgeted CAM for period
  actualCAM       Float           // actual CAM expenses
  variance        Float           // difference between budgeted and actual
  variancePercent Float           // variance as percentage
  
  // Tenant share calculation
  tenantShare     Float           // tenant's share percentage
  tenantCAM       Float           // tenant's CAM charges
  priorAdjustment Float?          // adjustment from prior period
  
  // Reconciliation amounts
  totalOwed       Float           // amount owed to/by tenant
  credits         Float?          // credits applied
  additionalRent  Float?          // additional rent due
  refundDue       Float?          // refund due to tenant
  
  // Supporting documentation
  auditTrail      Json?           // detailed calculation trail
  supportingDocs  Json?           // supporting document references
  
  // Dates
  reconciliationDate DateTime     // date of reconciliation
  dueDate         DateTime?       // payment due date
  paidDate        DateTime?       // date payment received/made
  
  // Dispute tracking
  disputeStatus   DisputeStatus   @default(NO_DISPUTE)
  disputeAmount   Float?          // disputed amount
  disputeReason   String?         // reason for dispute
  disputeDate     DateTime?       // date dispute raised
  resolutionDate  DateTime?       // date dispute resolved
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  // Relationships
  lease           Lease           @relation(fields: [leaseId], references: [id])
  leaseId         String
  expenses        CAMExpense[]
  variances       CAMVariance[]

  @@map("cam_reconciliations")
}

model CAMExpense {
  id              String        @id @default(uuid())
  expenseCategory String        // utilities, maintenance, security, etc.
  description     String
  budgetedAmount  Float
  actualAmount    Float
  variance        Float
  variancePercent Float
  
  // Allocation details
  allocationMethod String?      // square footage, percentage, etc.
  tenantShare     Float?        // tenant's share of this expense
  
  notes           String?
  
  // Relationships
  reconciliation  CAMReconciliation @relation(fields: [reconciliationId], references: [id])
  reconciliationId String

  @@map("cam_expenses")
}

model CAMVariance {
  id              String        @id @default(uuid())
  varianceType    VarianceType  @default(BUDGET)
  category        String
  description     String
  amount          Float
  percentage      Float
  
  // Analysis
  reason          String?       // reason for variance
  impact          String?       // impact assessment
  actionPlan      String?       // corrective action plan
  responsible     String?       // responsible party
  
  // Status
  status          VarianceStatus @default(OPEN)
  resolvedAt      DateTime?
  resolvedBy      String?
  
  // Relationships
  reconciliation  CAMReconciliation @relation(fields: [reconciliationId], references: [id])
  reconciliationId String

  @@map("cam_variances")
}

// Budget Planning and Forecasting Models
model Budget {
  id              String        @id @default(uuid())
  budgetName      String
  budgetType      BudgetType    @default(OPERATING)
  budgetPeriod    String        // YYYY for annual, YYYY-QQ for quarterly
  fiscalYear      Int
  
  // Budget amounts
  totalBudget     Float
  approvedBudget  Float?
  revisedBudget   Float?        // revised during the year
  
  // Status
  status          BudgetStatus  @default(DRAFT)
  version         String        @default("1.0")
  
  // Approval workflow
  preparedBy      String?
  reviewedBy      String?
  approvedBy      String?
  
  preparedAt      DateTime      @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  
  // Dates
  effectiveFrom   DateTime
  effectiveTo     DateTime
  
  // Notes
  assumptions     Json?         // budget assumptions
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  organization    Organization  @relation(fields: [organizationId], references: [id])
  organizationId  String
  property        Property?     @relation(fields: [propertyId], references: [id])
  propertyId      String?
  
  lineItems       BudgetLineItem[]
  variances       BudgetVariance[]
  forecasts       Forecast[]

  @@map("budgets")
}

model BudgetLineItem {
  id              String        @id @default(uuid())
  lineNumber      Int
  category        String        // revenue, operating_expense, capex, etc.
  subCategory     String?       // utilities, maintenance, leasing, etc.
  description     String
  
  // Budget amounts by period
  annualAmount    Float
  q1Amount        Float?
  q2Amount        Float?
  q3Amount        Float?
  q4Amount        Float?
  
  // Monthly breakdown
  monthlyAmounts  Json?         // 12-element array for monthly amounts
  
  // Calculation details
  calculationMethod String?     // per_sqft, percentage, fixed, etc.
  unitRate        Float?        // rate per unit
  units           Float?        // number of units
  escalationRate  Float?        // annual escalation percentage
  
  // Status
  isActive        Boolean       @default(true)
  notes           String?
  
  // Relationships
  budget          Budget        @relation(fields: [budgetId], references: [id])
  budgetId        String

  @@map("budget_line_items")
}

model Forecast {
  id              String        @id @default(uuid())
  forecastName    String
  forecastType    ForecastType  @default(REVENUE)
  forecastPeriod  String        // YYYY-MM or YYYY-QQ format
  
  // Forecast amounts
  forecastAmount  Float
  confidence      Float?        // confidence level 0-1
  
  // Variance from budget
  budgetAmount    Float?
  variance        Float?
  variancePercent Float?
  
  // Methodology
  forecastMethod  ForecastMethod @default(HISTORICAL)
  dataPoints      Json?          // historical data used
  assumptions     Json?          // forecast assumptions
  
  // Dates
  forecastDate    DateTime       @default(now())
  periodStart     DateTime
  periodEnd       DateTime
  
  // Status
  status          ForecastStatus @default(PRELIMINARY)
  reviewedBy      String?
  approvedBy      String?
  reviewedAt      DateTime?
  approvedAt      DateTime?
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  // Relationships
  budget          Budget?        @relation(fields: [budgetId], references: [id])
  budgetId        String?

  @@map("forecasts")
}

model BudgetVariance {
  id              String        @id @default(uuid())
  variancePeriod  String        // YYYY-MM format
  category        String
  description     String
  
  // Variance amounts
  budgetAmount    Float
  actualAmount    Float
  variance        Float
  variancePercent Float
  
  // Analysis
  varianceType    BudgetVarianceType @default(UNFAVORABLE)
  explanation     String?
  correctionPlan  String?
  responsible     String?
  
  // Status tracking
  status          VarianceStatus @default(OPEN)
  reviewedAt      DateTime?
  resolvedAt      DateTime?
  
  // Relationships
  budget          Budget        @relation(fields: [budgetId], references: [id])
  budgetId        String

  @@map("budget_variances")
}

