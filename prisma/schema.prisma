  predictedFailureDate DateTime?
  confidenceLevel   Float?              // 0-100
  remainingUsefulLife Float?            // in days
  
  // Alerts and Actions
  alertLevel        AlertLevel
  recommendedAction RecommendedAction
  urgencyLevel      UrgencyLevel
  
  // Analysis Results
  analysisDate      DateTime            @default(now())
  analysisMethod    String?             // algorithm/model used
  dataPoints        Int?                // number of data points analyzed
  
  // Relationships
  anomalies         String[]            // detected anomalies
  recommendations   String[]            // maintenance recommendations
  
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@map("condition_monitoring")
}

model ServiceLevelAgreement {
  id                String              @id @default(cuid())
  slaNumber         String              @unique
  slaName           String
  description       String?
  
  // Vendor Information
  vendorId          String
  vendorName        String
  contractNumber    String?
  
  // SLA Details
  serviceType       ServiceType
  serviceLevel      ServiceLevel
  
  // Response Times (in hours)
  emergencyResponseTime    Float?
  urgentResponseTime       Float?
  normalResponseTime       Float?
  lowResponseTime          Float?
  
  // Resolution Times (in hours)
  emergencyResolutionTime  Float?
  urgentResolutionTime     Float?
  normalResolutionTime     Float?
  lowResolutionTime        Float?
  
  // Availability Targets
  uptimeTarget      Float?              // percentage (e.g., 99.9)
  downtimeAllowance Float?              // hours per month
  
  // Performance Metrics
  qualityTarget     Float?              // percentage
  customerSatisfactionTarget Float?     // percentage
  
  // Contract Dates
  startDate         DateTime
  endDate           DateTime
  
  // Status
  status            SLAStatus
  
  // Performance Tracking
  currentPerformance Json?              // current metrics
  lastReviewDate    DateTime?
  nextReviewDate    DateTime?
  
  // Penalties and Credits
  penaltiesEnabled  Boolean             @default(false)
  creditsEnabled    Boolean             @default(false)
  penaltyStructure  Json?               // penalty calculation rules
  creditStructure   Json?               // credit calculation rules
  
  // Relationships
  performanceReports SLAPerformanceReport[]
  
  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String
  
  @@map("service_level_agreements")
}

model SLAPerformanceReport {
  id                String              @id @default(cuid())
  slaId             String
  sla               ServiceLevelAgreement @relation(fields: [slaId], references: [id])
  
  reportingPeriod   ReportingPeriod
  startDate         DateTime
  endDate           DateTime
  
  // Performance Metrics
  totalIncidents    Int                 @default(0)
  emergencyIncidents Int                @default(0)
  urgentIncidents   Int                 @default(0)
  normalIncidents   Int                 @default(0)
  lowIncidents      Int                 @default(0)
  
  // Response Time Performance
  avgEmergencyResponseTime Float?
  avgUrgentResponseTime    Float?
  avgNormalResponseTime    Float?
  avgLowResponseTime       Float?
  
  // Resolution Time Performance
  avgEmergencyResolutionTime Float?
  avgUrgentResolutionTime    Float?
  avgNormalResolutionTime    Float?
  avgLowResolutionTime       Float?
  
  // SLA Compliance
  responseTimeSLA   Float?              // percentage compliance
  resolutionTimeSLA Float?              // percentage compliance
  uptimeAchieved    Float?              // percentage
  qualityScore      Float?              // percentage
  customerSatisfaction Float?           // percentage
  
  // Penalties and Credits
  penaltiesApplied  Float               @default(0)
  creditsApplied    Float               @default(0)
  
  // Overall Score
  overallScore      Float?              // weighted average
  
  generatedDate     DateTime            @default(now())
  generatedBy       String
  
  @@unique([slaId, reportingPeriod, startDate])
  @@map("sla_performance_reports")
}

