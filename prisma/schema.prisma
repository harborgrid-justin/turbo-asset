// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Core User Management
model User {
  id            String   @id @default(uuid())
  email         String   @unique
  username      String   @unique
  firstName     String
  lastName      String
  passwordHash  String
  role          UserRole @default(USER)
  language      String   @default("en")
  timezone      String   @default("UTC")
  currency      String   @default("USD")
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  organization   Organization? @relation(fields: [organizationId], references: [id])
  organizationId String?
  department     Department?   @relation(fields: [departmentId], references: [id])
  departmentId   String?

  // Activity tracking
  workflowInstances WorkflowInstance[]
  approvals         Approval[]
  notifications     Notification[]
  documents         Document[]
  auditLogs         AuditLog[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  spaceBookings     SpaceBooking[]  @relation("UserBookings")
  bookingsFor       SpaceBooking[]  @relation("UserBookingsFor")
  moveRequests      MoveRequest[]   @relation("MoveRequests")
  moveApprovals     MoveRequest[]   @relation("MoveApprovals")
  moveDetails       MoveDetail[]    @relation("UserMoves")
  cadUploads        CADFile[]       @relation("CADUploads")

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  READONLY
}

// Organizations and Departments
model Organization {
  id            String  @id @default(uuid())
  name          String
  description   String?
  address       Json? // Flexible address structure
  defaultCurrency String @default("USD")
  defaultLanguage String @default("en")
  defaultTimezone String @default("UTC")
  isActive      Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  users       User[]
  departments Department[]
  properties  Property[]
  workflows   WorkflowDefinition[]
  customFields CustomFieldDefinition[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  chargebackRules   ChargebackRule[]
  spaceTemplates    SpaceTemplate[]

  @@map("organizations")
}

model Department {
  id             String  @id @default(uuid())
  name           String
  description    String?
  costCenter     String?
  managerId      String?
  isActive       Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relationships
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  users          User[]
  spaces         Space[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  chargebacks       ChargebackAllocation[]

  @@map("departments")
}

// Real Estate and Facilities Models
model Property {
  id              String      @id @default(uuid())
  name            String
  type            PropertyType
  address         Json // Structured address data
  totalArea       Float?
  usableArea      Float?
  currency        String      @default("USD")
  acquisitionCost Float?
  currentValue    Float?
  acquisitionDate DateTime?
  coordinates     Json? // Lat/Long for mapping
  timezone        String      @default("UTC")
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  buildings      Building[]
  customFields   CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  cadFiles          CADFile[]

  @@map("properties")
}

enum PropertyType {
  OFFICE
  WAREHOUSE
  RETAIL
  MANUFACTURING
  MIXED_USE
  RESIDENTIAL
  LAND
  OTHER
}

model Building {
  id              String  @id @default(uuid())
  name            String
  description     String?
  buildingCode    String? @unique
  totalArea       Float?
  floors          Int?
  constructionYear Int?
  renovationYear  Int?
  energyRating    String?
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  property   Property @relation(fields: [propertyId], references: [id])
  propertyId String
  floors     Floor[]
  assets     Asset[]
  customFields CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  emergencyPlans    EmergencyPlan[]
  cadFiles          CADFile[]

  @@map("buildings")
}

model Floor {
  id          String  @id @default(uuid())
  name        String
  floorNumber Int
  totalArea   Float?
  usableArea  Float?
  description String?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  building   Building @relation(fields: [buildingId], references: [id])
  buildingId String
  spaces     Space[]
  customFields CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  cadFiles          CADFile[]

  @@map("floors")
}

model Space {
  id            String    @id @default(uuid())
  name          String
  spaceCode     String?   @unique
  type          SpaceType
  area          Float?
  capacity      Int?
  description   String?
  rentableArea  Float?
  assignedDate  DateTime?
  vacatedDate   DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  floor        Floor       @relation(fields: [floorId], references: [id])
  floorId      String
  department   Department? @relation(fields: [departmentId], references: [id])
  departmentId String?
  assets       Asset[]
  customFields CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  bookings          SpaceBooking[]
  utilization       SpaceUtilization[]
  moveDetailsFrom   MoveDetail[]    @relation("MoveFromSpace")
  moveDetailsTo     MoveDetail[]    @relation("MoveToSpace")
  chargebacks       ChargebackAllocation[]

  @@map("spaces")
}

enum SpaceType {
  OFFICE
  CONFERENCE_ROOM
  COMMON_AREA
  STORAGE
  RESTROOM
  KITCHEN
  SERVER_ROOM
  LOBBY
  PARKING
  OTHER
}

// Asset Management
model Asset {
  id              String      @id @default(uuid())
  name            String
  assetTag        String      @unique
  type            AssetType
  category        String?
  manufacturer    String?
  model           String?
  serialNumber    String?
  purchaseDate    DateTime?
  purchasePrice   Float?
  currency        String      @default("USD")
  warrantyExpiry  DateTime?
  condition       AssetCondition @default(GOOD)
  status          AssetStatus @default(ACTIVE)
  description     String?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  building     Building? @relation(fields: [buildingId], references: [id])
  buildingId   String?
  space        Space?    @relation(fields: [spaceId], references: [id])
  spaceId      String?
  parentAsset  Asset?    @relation("AssetHierarchy", fields: [parentAssetId], references: [id])
  parentAssetId String?
  subAssets    Asset[]   @relation("AssetHierarchy")
  
  // Maintenance and workflows
  maintenanceRecords MaintenanceRecord[]
  customFields       CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  moveDetails       MoveDetail[]

  @@map("assets")
}

enum AssetType {
  FURNITURE
  EQUIPMENT
  TECHNOLOGY
  VEHICLE
  INFRASTRUCTURE
  OTHER
}

enum AssetCondition {
  EXCELLENT
  GOOD
  FAIR
  POOR
  OUT_OF_SERVICE
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  DISPOSED
  LOST
}

model MaintenanceRecord {
  id              String            @id @default(uuid())
  type            MaintenanceType
  description     String
  scheduledDate   DateTime?
  completedDate   DateTime?
  cost            Float?
  currency        String            @default("USD")
  vendor          String?
  status          MaintenanceStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relationships
  asset   Asset  @relation(fields: [assetId], references: [id])
  assetId String

  @@map("maintenance_records")
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  INSPECTION
  UPGRADE
}

enum MaintenanceStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  OVERDUE
}

// Workflow Engine
model WorkflowDefinition {
  id          String      @id @default(uuid())
  name        String
  description String?
  version     String      @default("1.0")
  definition  Json        // JSON workflow definition
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Relationships
  organization   Organization       @relation(fields: [organizationId], references: [id])
  organizationId String
  instances      WorkflowInstance[]

  @@map("workflow_definitions")
}

model WorkflowInstance {
  id               String           @id @default(uuid())
  status           WorkflowStatus   @default(PENDING)
  currentStep      String?
  data             Json             // Instance data
  startedAt        DateTime         @default(now())
  completedAt      DateTime?
  dueDate          DateTime?
  priority         WorkflowPriority @default(NORMAL)
  notes            String?

  // Relationships
  definition       WorkflowDefinition @relation(fields: [definitionId], references: [id])
  definitionId     String
  initiatedBy      User               @relation(fields: [initiatedById], references: [id])
  initiatedById    String
  approvals        Approval[]

  @@map("workflow_instances")
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum WorkflowPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Approval {
  id         String         @id @default(uuid())
  status     ApprovalStatus @default(PENDING)
  comments   String?
  approvedAt DateTime?
  createdAt  DateTime       @default(now())

  // Relationships
  workflow   WorkflowInstance @relation(fields: [workflowId], references: [id])
  workflowId String
  approver   User             @relation(fields: [approverId], references: [id])
  approverId String

  @@map("approvals")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  DELEGATED
}

// Custom Fields System
model CustomFieldDefinition {
  id               String              @id @default(uuid())
  name             String
  fieldType        CustomFieldType
  entityType       String              // Which entity this field applies to
  isRequired       Boolean             @default(false)
  isUnique         Boolean             @default(false)
  defaultValue     String?
  validationRules  Json?               // Validation configuration
  options          Json?               // For select fields
  dependencies     Json?               // Field dependencies
  displayOrder     Int                 @default(0)
  isActive         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  // Relationships
  organization   Organization       @relation(fields: [organizationId], references: [id])
  organizationId String
  values         CustomFieldValue[]

  @@map("custom_field_definitions")
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
  SELECT
  MULTI_SELECT
  EMAIL
  URL
  PHONE
  CURRENCY
  PERCENTAGE
  RICH_TEXT
}

model CustomFieldValue {
  id        String   @id @default(uuid())
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  fieldDefinition   CustomFieldDefinition @relation(fields: [fieldDefinitionId], references: [id])
  fieldDefinitionId String
  entityId          String                // ID of the entity this value belongs to
  entityType        String                // Type of entity

  // Polymorphic relationships - one will be set based on entityType
  property Property? @relation(fields: [propertyId], references: [id])
  propertyId String?
  building Building? @relation(fields: [buildingId], references: [id])
  buildingId String?
  floor    Floor?    @relation(fields: [floorId], references: [id])
  floorId  String?
  space    Space?    @relation(fields: [spaceId], references: [id])
  spaceId  String?
  asset    Asset?    @relation(fields: [assetId], references: [id])
  assetId  String?

  @@map("custom_field_values")
}

// Document Management
model Document {
  id          String         @id @default(uuid())
  name        String
  description String?
  fileName    String
  filePath    String
  fileSize    Int
  mimeType    String
  version     String         @default("1.0")
  checksum    String
  metadata    Json?
  tags        String[]
  status      DocumentStatus @default(ACTIVE)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relationships
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  versions     DocumentVersion[]
  permissions  DocumentPermission[]

  @@map("documents")
}

enum DocumentStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DELETED
}

model DocumentVersion {
  id          String   @id @default(uuid())
  version     String
  fileName    String
  filePath    String
  fileSize    Int
  checksum    String
  changeNotes String?
  createdAt   DateTime @default(now())

  // Relationships
  document   Document @relation(fields: [documentId], references: [id])
  documentId String

  @@map("document_versions")
}

model DocumentPermission {
  id         String           @id @default(uuid())
  entityType String           // user, role, department
  entityId   String
  permission DocumentAccess
  createdAt  DateTime         @default(now())

  // Relationships
  document   Document @relation(fields: [documentId], references: [id])
  documentId String

  @@map("document_permissions")
}

enum DocumentAccess {
  READ
  WRITE
  DELETE
  ADMIN
}

// Notifications and Messaging
model Notification {
  id          String             @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  priority    NotificationPriority @default(NORMAL)
  isRead      Boolean            @default(false)
  readAt      DateTime?
  data        Json?              // Additional data for the notification
  createdAt   DateTime           @default(now())

  // Relationships
  recipient   User   @relation(fields: [recipientId], references: [id])
  recipientId String

  @@map("notifications")
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  WORKFLOW
  SYSTEM
  MAINTENANCE
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// Audit and Logging
model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())

  // Relationships
  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  @@map("audit_logs")
}

// System Configuration
model SystemConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}

// Integration Records
model IntegrationRecord {
  id            String            @id @default(uuid())
  system        IntegrationType
  externalId    String
  entityType    String
  entityId      String
  syncStatus    IntegrationStatus @default(PENDING)
  lastSyncAt    DateTime?
  syncData      Json?
  errorMessage  String?
  retryCount    Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@map("integration_records")
}

enum IntegrationType {
  SAP
  ORACLE
  WORKDAY
  SERVICENOW
  GENERIC_API
  FILE_IMPORT
}

enum IntegrationStatus {
  PENDING
  IN_PROGRESS
  SUCCESS
  FAILED
  PARTIAL
}

// ========================================
// PHASE 3: SPACE MANAGEMENT & PORTFOLIO TRACKING
// ========================================

// Space Booking & Hoteling System
model SpaceBooking {
  id            String              @id @default(uuid())
  bookingType   SpaceBookingType    @default(DESK)
  startDateTime DateTime
  endDateTime   DateTime
  isRecurring   Boolean             @default(false)
  recurrence    Json?               // Recurrence pattern
  purpose       String?
  guestCount    Int?                @default(0)
  equipment     Json?               // Requested equipment/amenities
  status        BookingStatus       @default(PENDING)
  checkInAt     DateTime?
  checkOutAt    DateTime?
  noShowAt      DateTime?
  cancelledAt   DateTime?
  cancellationReason String?
  isActive      Boolean             @default(true)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  // Relationships
  space         Space               @relation(fields: [spaceId], references: [id])
  spaceId       String
  bookedBy      User                @relation("UserBookings", fields: [bookedById], references: [id])
  bookedById    String
  bookedFor     User?               @relation("UserBookingsFor", fields: [bookedForId], references: [id])
  bookedForId   String?

  @@map("space_bookings")
}

enum SpaceBookingType {
  DESK
  OFFICE
  CONFERENCE_ROOM
  PARKING_SPOT
  LOCKER
  PHONE_BOOTH
  COLLABORATION_SPACE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW
  EXPIRED
}

// Space Utilization & Occupancy Tracking
model SpaceUtilization {
  id            String            @id @default(uuid())
  recordDate    DateTime          @default(now())
  utilizationType UtilizationType @default(OCCUPANCY)
  value         Float
  unit          String            // percentage, people, hours, etc.
  dataSource    DataSourceType    @default(MANUAL)
  sensorId      String?           // For IoT sensor integration
  metadata      Json?             // Additional sensor data
  createdAt     DateTime          @default(now())

  // Relationships
  space         Space             @relation(fields: [spaceId], references: [id])
  spaceId       String

  @@map("space_utilization")
}

enum UtilizationType {
  OCCUPANCY          // Current occupancy
  UTILIZATION        // Usage percentage over time
  PEAK_OCCUPANCY     // Maximum occupancy in period
  AVERAGE_OCCUPANCY  // Average occupancy in period
  BOOKING_RATE       // Booking vs available time
  FOOT_TRAFFIC      // People passing through
  ENVIRONMENTAL     // Temperature, CO2, etc.
}

enum DataSourceType {
  MANUAL
  SENSOR
  BADGE_SCAN
  WIFI_TRACKING
  BOOKING_SYSTEM
  CAMERA_AI
  IMPORTED
}

// Move Management System
model MoveRequest {
  id              String        @id @default(uuid())
  requestNumber   String        @unique
  moveType        MoveType      @default(INTERNAL)
  requestedDate   DateTime
  scheduledDate   DateTime?
  completedDate   DateTime?
  urgency         MovePriority  @default(NORMAL)
  reason          String?
  description     String?
  estimatedCost   Float?
  actualCost      Float?
  currency        String        @default("USD")
  status          MoveStatus    @default(PENDING)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  requestedBy     User          @relation("MoveRequests", fields: [requestedById], references: [id])
  requestedById   String
  approvedBy      User?         @relation("MoveApprovals", fields: [approvedById], references: [id])
  approvedById    String?
  
  // Move details
  moveDetails     MoveDetail[]
  vendors         MoveVendor[]
  costs           MoveCost[]

  @@map("move_requests")
}

model MoveDetail {
  id              String      @id @default(uuid())
  itemType        String      // person, asset, furniture, etc.
  itemDescription String
  quantity        Int         @default(1)
  
  // From location
  fromSpace       Space?      @relation("MoveFromSpace", fields: [fromSpaceId], references: [id])
  fromSpaceId     String?
  fromLocation    String?     // Free text if not in system
  
  // To location  
  toSpace         Space?      @relation("MoveToSpace", fields: [toSpaceId], references: [id])
  toSpaceId       String?
  toLocation      String?     // Free text if not in system
  
  specialInstructions String?
  isCompleted     Boolean     @default(false)
  completedAt     DateTime?
  
  // Relationships
  moveRequest     MoveRequest @relation(fields: [moveRequestId], references: [id])
  moveRequestId   String
  
  // Optional asset reference
  asset           Asset?      @relation(fields: [assetId], references: [id])
  assetId         String?
  
  // Optional user reference for personnel moves
  user            User?       @relation("UserMoves", fields: [userId], references: [id])
  userId          String?

  @@map("move_details")
}

model MoveVendor {
  id            String      @id @default(uuid())
  vendorName    String
  contactInfo   Json        // Phone, email, address
  serviceType   String      // moving, cleaning, IT setup, etc.
  quotedCost    Float?
  actualCost    Float?
  currency      String      @default("USD")
  isSelected    Boolean     @default(false)
  performanceRating Int?     // 1-5 stars
  notes         String?
  
  // Relationships
  moveRequest   MoveRequest @relation(fields: [moveRequestId], references: [id])
  moveRequestId String

  @@map("move_vendors")
}

model MoveCost {
  id            String      @id @default(uuid())
  category      String      // labor, materials, transportation, etc.
  description   String
  estimatedCost Float?
  actualCost    Float?
  currency      String      @default("USD")
  invoiceNumber String?
  paidAt        DateTime?
  
  // Relationships
  moveRequest   MoveRequest @relation(fields: [moveRequestId], references: [id])
  moveRequestId String

  @@map("move_costs")
}

enum MoveType {
  INTERNAL      // Within same building/property
  EXTERNAL      // Between different properties
  NEW_HIRE      // New employee setup
  TERMINATION   // Employee departure cleanup
  RENOVATION    // Temporary relocation
  EXPANSION     // Department growth
  CONSOLIDATION // Department merger/reduction
}

enum MovePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MoveStatus {
  PENDING
  APPROVED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REJECTED
}

// Chargeback & Cost Allocation
model ChargebackRule {
  id              String            @id @default(uuid())
  name            String
  description     String?
  entityType      String            // space, asset, service
  costCategory    String            // rent, utilities, maintenance, etc.
  allocationMethod AllocationMethod @default(SQUARE_FOOTAGE)
  rate            Float?            // Cost per unit
  currency        String            @default("USD")
  isActive        Boolean           @default(true)
  effectiveDate   DateTime          @default(now())
  expiryDate      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Relationships
  organization    Organization      @relation(fields: [organizationId], references: [id])
  organizationId  String
  allocations     ChargebackAllocation[]

  @@map("chargeback_rules")
}

model ChargebackAllocation {
  id              String        @id @default(uuid())
  period          String        // YYYY-MM format
  totalCost       Float
  allocatedCost   Float
  allocationBasis Float?        // Square footage, headcount, etc.
  currency        String        @default("USD")
  createdAt       DateTime      @default(now())

  // Relationships
  rule            ChargebackRule @relation(fields: [ruleId], references: [id])
  ruleId          String
  department      Department     @relation(fields: [departmentId], references: [id])
  departmentId    String
  space           Space?         @relation(fields: [spaceId], references: [id])
  spaceId         String?

  @@map("chargeback_allocations")
}

enum AllocationMethod {
  SQUARE_FOOTAGE
  HEADCOUNT
  FIXED_PERCENTAGE
  USAGE_BASED
  ASSET_COUNT
  MANUAL
}

// Space Templates & Standards
model SpaceTemplate {
  id              String        @id @default(uuid())
  name            String
  category        String        // office-standards, meeting-rooms, etc.
  spaceType       SpaceType
  minArea         Float?
  maxArea         Float?
  standardArea    Float?
  capacity        Int?
  description     String?
  requirements    Json?         // Furniture, equipment, technical specs
  compliance      Json?         // Safety, accessibility, building codes
  cost            Float?        // Standard setup/fit-out cost
  currency        String        @default("USD")
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  organization    Organization  @relation(fields: [organizationId], references: [id])
  organizationId  String

  @@map("space_templates")
}

// Emergency Planning & Compliance
model EmergencyPlan {
  id              String        @id @default(uuid())
  name            String
  planType        String        // evacuation, lockdown, medical, fire, etc.
  description     String?
  procedures      Json          // Step-by-step procedures
  contacts        Json          // Emergency contacts
  zones           Json          // Building zones and routes
  capacity        Int?          // Maximum occupancy for safety
  lastReviewed    DateTime?
  nextReview      DateTime?
  complianceNotes String?
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  building        Building      @relation(fields: [buildingId], references: [id])
  buildingId      String
  drills          EmergencyDrill[]

  @@map("emergency_plans")
}

model EmergencyDrill {
  id              String        @id @default(uuid())
  drillType       String        // fire, evacuation, lockdown, etc.
  scheduledDate   DateTime
  completedDate   DateTime?
  participantCount Int?
  evacuationTime  Int?          // Seconds to complete
  issues          Json?         // Problems encountered
  improvements    Json?         // Recommended improvements  
  complianceScore Int?          // 1-100 score
  notes           String?
  isCompleted     Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relationships
  plan            EmergencyPlan @relation(fields: [planId], references: [id])
  planId          String

  @@map("emergency_drills")
}

// CAD File Integration
model CADFile {
  id              String        @id @default(uuid())
  filename        String
  originalName    String
  fileType        CADFileType
  fileSize        BigInt
  version         String        @default("1.0")
  description     String?
  metadata        Json?         // CAD-specific metadata
  layers          Json?         // Layer information
  coordinates     Json?         // Coordinate system info
  scale           String?       // Drawing scale
  units           String?       // measurement units
  uploadedAt      DateTime      @default(now())
  lastModified    DateTime      @updatedAt
  isActive        Boolean       @default(true)

  // File storage info
  storageProvider String        // local, s3, azure, gcp
  storagePath     String
  publicUrl       String?

  // Relationships
  uploadedBy      User          @relation("CADUploads", fields: [uploadedById], references: [id])
  uploadedById    String
  property        Property?     @relation(fields: [propertyId], references: [id])
  propertyId      String?
  building        Building?     @relation(fields: [buildingId], references: [id])
  buildingId      String?
  floor           Floor?        @relation(fields: [floorId], references: [id])
  floorId         String?

  @@map("cad_files")
}

enum CADFileType {
  DWG           // AutoCAD
  DXF           // AutoCAD Exchange
  RVT           // Revit
  PLN           // ArchiCAD
  IFC           // Industry Foundation Classes
  PDF           // PDF drawings
  JPG           // Raster image
  PNG           // Raster image
  SVG           // Vector graphics
}

