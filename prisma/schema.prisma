}

// CAD File Integration
model CADFile {
  id              String        @id @default(uuid())
  filename        String
  originalName    String
  fileType        CADFileType
  fileSize        BigInt
  version         String        @default("1.0")
  description     String?
  metadata        Json?         // CAD-specific metadata
  layers          Json?         // Layer information
  coordinates     Json?         // Coordinate system info
  scale           String?       // Drawing scale
  units           String?       // measurement units
  uploadedAt      DateTime      @default(now())
  lastModified    DateTime      @updatedAt
  isActive        Boolean       @default(true)

  // File storage info
  storageProvider String        // local, s3, azure, gcp
  storagePath     String
  publicUrl       String?

  // Relationships
  uploadedBy      User          @relation("CADUploads", fields: [uploadedById], references: [id])
  uploadedById    String
  property        Property?     @relation(fields: [propertyId], references: [id])
  propertyId      String?
  building        Building?     @relation(fields: [buildingId], references: [id])
  buildingId      String?
  floor           Floor?        @relation(fields: [floorId], references: [id])
  floorId         String?

  @@map("cad_files")
}

enum CADFileType {
  DWG           // AutoCAD
  DXF           // AutoCAD Exchange
  RVT           // Revit
  PLN           // ArchiCAD
  IFC           // Industry Foundation Classes
  PDF           // PDF drawings
  JPG           // Raster image
  PNG           // Raster image
  SVG           // Vector graphics
}

// ========================================
// PHASE 4: LEASE ADMINISTRATION & FINANCIAL MANAGEMENT
// ========================================

// Lease Management Models
model Lease {
  id              String        @id @default(uuid())
  leaseNumber     String        @unique
  leaseName       String
  leaseType       LeaseType     @default(OPERATING)
  status          LeaseStatus   @default(ACTIVE)
  
  // Lease terms
  startDate       DateTime
  endDate         DateTime
  originalTerm    Int           // months
  currentTerm     Int?          // remaining months
  renewalOptions  Json?         // renewal terms and options
  escalationRules Json?         // rent escalation rules
  
  // Financial terms
  baseLease       Float
  percentage      Float?        // percentage rent
  currency        String        @default("USD")
  securityDeposit Float?
  
  // Lease details
  leasableArea    Float?        // square footage
  usableArea      Float?        // usable square footage
  unitType        String?       // office, retail, warehouse, etc.
  useType         String?       // permitted use
  exclusiveRights Json?         // exclusive use rights
  
  // Critical dates
  commencement    DateTime?
  rentCommencement DateTime?
  expirationDate  DateTime
  optionDeadline  DateTime?
  renewalNotice   DateTime?
  
  // Additional terms
  capex           Float?        // capital expenditures
  personalProperty Float?       // personal property value
  notes           String?
  
  // Status tracking
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  property        Property      @relation(fields: [propertyId], references: [id])
  propertyId      String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  
  // Related records
  contracts       LeaseContract[]
  rentRoll        RentRoll[]
  criticalDates   CriticalDate[]
  accounting      LeaseAccounting[]
  camCharges      CAMReconciliation[]
  payments        LeasePayment[]
  documents       LeaseDocument[]
  amendments      LeaseAmendment[]

  @@map("leases")
}

model Tenant {
  id              String        @id @default(uuid())
  name            String
  legalName       String?
  tenantType      TenantType    @default(COMMERCIAL)
  industry        String?
  contactInfo     Json          // phone, email, address
  creditRating    String?       // AAA, AA, A, BBB, etc.
  sicCode         String?       // Standard Industrial Classification
  naicsCode       String?       // North American Industry Classification
  
  // Financial info
  annualRevenue   Float?
  employeeCount   Int?
  publicCompany   Boolean       @default(false)
  parentCompany   String?
  
  // Contact details
  primaryContact  String?
  billingContact  String?
  legalContact    String?
  
  // Status
  status          TenantStatus  @default(ACTIVE)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  leases          Lease[]
  guarantees      TenantGuarantee[]
  brokers         TenantBroker[]

  @@map("tenants")
}

model LeaseContract {
  id              String          @id @default(uuid())
  contractNumber  String          @unique
  contractType    ContractType    @default(LEASE)
  version         String          @default("1.0")
  status          ContractStatus  @default(DRAFT)
  
  // Contract details
  executionDate   DateTime?
  effectiveDate   DateTime?
  expirationDate  DateTime?
  autoRenew       Boolean         @default(false)
  renewalTerms    Json?
  
  // Document management
  originalDocument String?        // file path or URL
  signedDocument  String?         // signed version
  documentHash    String?         // for integrity verification
  
  // Terms and conditions
  terms           Json            // contract terms as JSON
  clauses         Json?           // special clauses
  amendments      Json?           // amendment history
  
  // Parties
  lessor          Json            // lessor information
  lessee          Json            // lessee information
  guarantors      Json?           // guarantor information
  
  // Financial terms
