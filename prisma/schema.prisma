// ================================
// PHASE 5: MAINTENANCE & ASSET MANAGEMENT
// ================================

// Asset Management Models
model MaintenanceAsset {
  id                String              @id @default(cuid())
  assetId           String              @unique
  assetTag          String              @unique
  assetName         String
  description       String?
  category          AssetCategory
  subcategory       String?
  manufacturer      String?
  model             String?
  serialNumber      String?
  location          String
  building          String?
  floor             String?
  room              String?
  status            AssetStatus
  condition         AssetCondition
  criticality       AssetCriticality
  
  // Financial Information
  purchasePrice     Float?
  purchaseDate      DateTime?
  warrantyExpiry    DateTime?
  depreciationMethod DepreciationMethod?
  usefulLife        Int?                // in years
  salvageValue      Float?
  currentValue      Float?
  
  // Maintenance Information
  lastMaintenanceDate DateTime?
  nextMaintenanceDate DateTime?
  maintenanceInterval Int?              // in days
  maintenanceCost     Float             @default(0)
  
  // Relationships
  workOrders        WorkOrder[]
  preventiveMaintenance PreventiveMaintenance[]
  assetConditions   AssetConditionRecord[]
  depreciations     AssetDepreciation[]
  iotDevices        IoTDevice[]
  energyMeters      EnergyMeter[]
  
  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String
  
  @@map("maintenance_assets")
}

model WorkOrder {
  id                String              @id @default(cuid())
  workOrderNumber   String              @unique
  title             String
  description       String?
  priority          WorkOrderPriority
  status            WorkOrderStatus
  type              WorkOrderType
  category          String?
  
  // Asset Information
  assetId           String?
  asset             MaintenanceAsset?   @relation(fields: [assetId], references: [id])
  location          String
  building          String?
  floor             String?
  room              String?
  
  // Scheduling
  requestedDate     DateTime
  scheduledDate     DateTime?
  startDate         DateTime?
  completionDate    DateTime?
  dueDate           DateTime?
  
  // Assignment
  assignedTo        String?
  assignedTechnician String?
  assignedTeam      String?
  estimatedHours    Float?
  actualHours       Float?
  
  // Cost Information
  estimatedCost     Float?
  actualCost        Float               @default(0)
  laborCost         Float               @default(0)
  materialCost      Float               @default(0)
  contractorCost    Float               @default(0)
  
  // Approval Workflow
  requiresApproval  Boolean             @default(false)
  approvalStatus    ApprovalStatus      @default(PENDING)
  approvedBy        String?
  approvedDate      DateTime?
  
  // Relationships
  tasks             WorkOrderTask[]
  materials         WorkOrderMaterial[]
  timeEntries       WorkOrderTimeEntry[]
  attachments       WorkOrderAttachment[]
  parentWorkOrder   WorkOrder?          @relation("WorkOrderHierarchy", fields: [parentWorkOrderId], references: [id])
  parentWorkOrderId String?
  subWorkOrders     WorkOrder[]         @relation("WorkOrderHierarchy")
  
  // Prevention Maintenance Link
  preventiveMaintenanceId String?
  preventiveMaintenance PreventiveMaintenance? @relation(fields: [preventiveMaintenanceId], references: [id])
  
  organizationId    String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  createdBy         String
  
  @@map("work_orders")
}

model WorkOrderTask {
  id              String              @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  taskNumber      Int
  title           String
  description     String?
  status          TaskStatus
  priority        TaskPriority
  
  // Assignment
  assignedTo      String?
  estimatedHours  Float?
  actualHours     Float?
  
  // Scheduling
  startDate       DateTime?
  completionDate  DateTime?
  dueDate         DateTime?
  
  // Dependencies
  dependsOnTaskId String?
  dependsOnTask   WorkOrderTask?      @relation("TaskDependency", fields: [dependsOnTaskId], references: [id])
  dependentTasks  WorkOrderTask[]     @relation("TaskDependency")
  
  // Instructions and Safety
  instructions    String?
  safetyNotes     String?
  skillsRequired  String[]
  toolsRequired   String[]
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@map("work_order_tasks")
}

model WorkOrderMaterial {
  id              String              @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  inventoryItemId String?
  inventoryItem   InventoryItem?      @relation(fields: [inventoryItemId], references: [id])
  
  itemName        String
  description     String?
  quantity        Float
  unitOfMeasure   String
  unitCost        Float
  totalCost       Float
  
  status          MaterialStatus
  requestedDate   DateTime
  deliveredDate   DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@map("work_order_materials")
}

model WorkOrderTimeEntry {
  id              String              @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  technicianId    String
  technicianName  String
  startTime       DateTime
  endTime         DateTime?
  hoursWorked     Float?
  hourlyRate      Float?
  totalCost       Float?
  
  description     String?
  workPerformed   String?
  
  status          TimeEntryStatus
  approvedBy      String?
  approvedDate    DateTime?
  
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  
  @@map("work_order_time_entries")
}

model WorkOrderAttachment {
  id              String              @id @default(cuid())
  workOrderId     String
  workOrder       WorkOrder           @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  
  fileName        String
  originalName    String
  fileSize        Int
  mimeType        String
  filePath        String
  uploadedBy      String
  uploadedAt      DateTime            @default(now())
  
  @@map("work_order_attachments")
}

model PreventiveMaintenance {
  id                String              @id @default(cuid())
  pmNumber          String              @unique
  title             String
  description       String?
  
  // Asset Association
  assetId           String
  asset             MaintenanceAsset    @relation(fields: [assetId], references: [id])
  
  // Scheduling
  frequency         PMFrequency
  frequencyValue    Int                 // e.g., every 30 days
  frequencyUnit     FrequencyUnit       // DAYS, WEEKS, MONTHS, YEARS
  
  // Calendar-based scheduling
  startDate         DateTime
  endDate           DateTime?
  lastPerformed     DateTime?
  nextDue           DateTime
  
  // Usage-based scheduling
  usageInterval     Float?              // e.g., every 1000 hours
