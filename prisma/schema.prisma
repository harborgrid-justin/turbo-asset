model ContractVendor {
  id              String        @id @default(uuid())
  role            VendorRole    @default(GENERAL)
  startDate       DateTime?
  endDate         DateTime?
  
  // Contract terms
  contractValue   Float?
  paymentTerms    Json?
  deliverables    Json?
  
  // Performance
  performanceRating Float?      // 1-5 scale
  onTimeDelivery  Boolean?
  onBudget        Boolean?
  qualityRating   Float?        // 1-5 scale
  
  // Status
  status          ContractVendorStatus @default(ACTIVE)
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  contract        LeaseContract @relation(fields: [contractId], references: [id])
  contractId      String
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  vendorId        String

  @@map("contract_vendors")
}

// Financial Consolidation Models
model FinancialStatement {
  id              String        @id @default(uuid())
  statementType   StatementType @default(INCOME_STATEMENT)
  period          String        // YYYY-MM or YYYY-QQ format
  fiscalYear      Int
  fiscalPeriod    Int           // month or quarter number
  
  // Consolidation details
  consolidationLevel ConsolidationLevel @default(PROPERTY)
  entityId        String        // property, building, or organization ID
  entityType      String        // property, building, organization
  
  // Statement data
  revenue         Float         @default(0)
  operatingExpenses Float       @default(0)
  netOperatingIncome Float      @default(0)
  capitalExpenses Float         @default(0)
  depreciation    Float         @default(0)
  netIncome       Float         @default(0)
  
  // Balance sheet items (if applicable)
  assets          Float?
  liabilities     Float?
  equity          Float?
  
  // Cash flow items (if applicable)
  operatingCashFlow Float?
  investingCashFlow Float?
  financingCashFlow Float?
  netCashFlow     Float?
  
  // Status
  status          StatementStatus @default(DRAFT)
  preparedBy      String?
  reviewedBy      String?
  approvedBy      String?
  
  preparedAt      DateTime      @default(now())
  reviewedAt      DateTime?
  approvedAt      DateTime?
  
  // Version control
  version         String        @default("1.0")
  isConsolidated  Boolean       @default(false)
  parentStatement String?       // ID of parent consolidated statement
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  organization    Organization  @relation(fields: [organizationId], references: [id])
  organizationId  String
  
  lineItems       FinancialLineItem[]
  consolidationRules ConsolidationRule[]

  @@map("financial_statements")
}

model FinancialLineItem {
  id              String        @id @default(uuid())
  lineNumber      Int
  accountCode     String
  accountName     String
  lineType        LineItemType  @default(EXPENSE)
  
  // Amounts
  budgetAmount    Float?
  actualAmount    Float
  priorYearAmount Float?
  variance        Float?
  variancePercent Float?
  
  // Classification
  category        String        // operating, non-operating, etc.
  subCategory     String?
  glAccount       String?       // general ledger account
  costCenter      String?
  department      String?
  
  // Notes
  notes           String?
  
  // Relationships
  statement       FinancialStatement @relation(fields: [statementId], references: [id])
  statementId     String

  @@map("financial_line_items")
}

model ConsolidationRule {
  id              String        @id @default(uuid())
  ruleName        String
  ruleType        ConsolidationRuleType @default(AGGREGATION)
  
  // Rule definition
  sourceEntities  Json          // entities to consolidate from
  targetEntity    String        // target entity ID
  mappingRules    Json          // account mapping rules
  
  // Calculation rules
  calculationMethod String      // SUM, AVERAGE, WEIGHTED_AVERAGE, etc.
  weights         Json?         // weighting factors if applicable
  adjustments     Json?         // consolidation adjustments
  
  // Elimination rules
  intercompanyEliminations Json? // intercompany eliminations
  
  // Status
  isActive        Boolean       @default(true)
  effectiveDate   DateTime      @default(now())
  expiryDate      DateTime?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  statement       FinancialStatement @relation(fields: [statementId], references: [id])
  statementId     String

  @@map("consolidation_rules")
}

// Additional Supporting Models
model RentRoll {
  id              String        @id @default(uuid())
  rollDate        DateTime      @default(now())
  rollPeriod      String        // YYYY-MM format
  
  // Rent details
  baseRent        Float
  percentageRent  Float?
  additionalRent  Float?        // CAM, taxes, insurance
  totalRent       Float
  
  // Occupancy
  leasableArea    Float?
  occupiedArea    Float?
  occupancyRate   Float?
  
  // Calculations
  rentPerSqFt     Float?
  annualizedRent  Float?
  
  // Status
  status          RentRollStatus @default(CURRENT)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  lease           Lease         @relation(fields: [leaseId], references: [id])
  leaseId         String

  @@map("rent_roll")
}

model LeasePayment {
  id              String        @id @default(uuid())
  paymentType     PaymentType   @default(BASE_RENT)
  paymentDate     DateTime
  dueDate         DateTime
  amount          Float
  currency        String        @default("USD")
  
  // Payment details
  paymentMethod   PaymentMethod @default(CHECK)
  checkNumber     String?
  reference       String?
  
  // Status
  status          PaymentStatus @default(PENDING)
  paidDate        DateTime?
  clearedDate     DateTime?
  
  // Late fees
  lateFeeAmount   Float?
  daysPastDue     Int?
  
  // Reconciliation
  reconciledDate  DateTime?
  reconciledBy    String?
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  lease           Lease         @relation(fields: [leaseId], references: [id])
  leaseId         String

  @@map("lease_payments")
}

model LeaseDocument {
  id              String        @id @default(uuid())
  documentType    LeaseDocumentType @default(LEASE_AGREEMENT)
  documentName    String
  description     String?
  
  // File details
  fileName        String
  filePath        String
  fileSize        Int
  mimeType        String
  
  // Version control
  version         String        @default("1.0")
  isLatestVersion Boolean       @default(true)
  
  // Document management
  uploadDate      DateTime      @default(now())
  uploadedBy      String
  reviewedBy      String?
  approvedBy      String?
  reviewDate      DateTime?
  approvalDate    DateTime?
  
  // Status
  status          DocumentStatus @default(DRAFT)
  
  // Security
  isConfidential  Boolean       @default(false)
  accessLevel     String?       // public, internal, confidential
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  lease           Lease         @relation(fields: [leaseId], references: [id])
  leaseId         String

  @@map("lease_documents")
}

model LeaseAmendment {
  id              String        @id @default(uuid())
  amendmentNumber String        @unique
  amendmentType   AmendmentType @default(RENT_CHANGE)
  effectiveDate   DateTime
  
  // Amendment details
  description     String
  changes         Json          // detailed changes made
  previousValues  Json          // original values before amendment
  newValues       Json          // new values after amendment
  
  // Financial impact
  financialImpact Float?        // net financial impact
  currency        String        @default("USD")
  
  // Approval
  status          AmendmentStatus @default(PENDING)
  requestedBy     String
  approvedBy      String?
  requestDate     DateTime      @default(now())
  approvalDate    DateTime?
  
  // Documentation
  documentPath    String?       // path to amendment document
  signedDate      DateTime?
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  lease           Lease         @relation(fields: [leaseId], references: [id])
  leaseId         String

  @@map("lease_amendments")
}

model TenantGuarantee {
  id              String        @id @default(uuid())
  guaranteeType   GuaranteeType @default(PERSONAL)
  guarantorName   String
  guarantorInfo   Json          // contact and financial info
  
  // Guarantee terms
  guaranteeAmount Float
  effectiveDate   DateTime
  expirationDate  DateTime?
  
  // Documentation
  documentPath    String?
  signedDate      DateTime?
  
  // Status
  status          GuaranteeStatus @default(ACTIVE)
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String

  @@map("tenant_guarantees")
}

model TenantBroker {
  id              String        @id @default(uuid())
  brokerType      BrokerType    @default(TENANT_REP)
  startDate       DateTime?
  endDate         DateTime?
  
  // Commission
  commissionRate  Float?
  commissionAmount Float?
  commissionPaid  Boolean       @default(false)
  paymentDate     DateTime?
  
  // Relationship details
  exclusivity     Boolean       @default(false)
  territory       String?
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  tenantId        String
  broker          Broker        @relation(fields: [brokerId], references: [id])
  brokerId        String

  @@map("tenant_brokers")
}

model VendorInvoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique
  invoiceDate     DateTime
  dueDate         DateTime
  amount          Float
  currency        String        @default("USD")
  
  // Invoice details
  description     String
  servicesPeriod  String?       // period services were provided
  
  // Payment terms
  paymentTerms    String?       // NET 30, etc.
  discountTerms   String?       // 2/10 NET 30, etc.
  
  // Status
  status          InvoiceStatus @default(PENDING)
  approvedBy      String?
  approvedDate    DateTime?
  paidDate        DateTime?
  paidAmount      Float?
  
  // Matching
  poNumber        String?       // purchase order number
  receivingNumber String?       // receiving document number
  
  notes           String?
  
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  
  // Relationships
  vendor          Vendor        @relation(fields: [vendorId], references: [id])
  vendorId        String

  @@map("vendor_invoices")
}

// Extend Organization model for Phase 4 relationships
model Property {
  id              String      @id @default(uuid())
  name            String
  type            PropertyType
  address         Json // Structured address data
  totalArea       Float?
  usableArea      Float?
  currency        String      @default("USD")
  acquisitionCost Float?
  currentValue    Float?
  acquisitionDate DateTime?
  coordinates     Json? // Lat/Long for mapping
  timezone        String      @default("UTC")
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  // Relationships
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  buildings      Building[]
  customFields   CustomFieldValue[]

  // Phase 3: Space Management & Portfolio Tracking relationships
  cadFiles          CADFile[]
  
  // Phase 4: Lease Administration & Financial Management relationships
  leases            Lease[]
  budgets           Budget[]

  @@map("properties")
}

