{
  "name": "@turbo-asset/packages",
  "version": "1.0.0",
  "description": "NAPI-RS packages for Turbo Asset IWMS platform",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
