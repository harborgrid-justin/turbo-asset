# Database
DATABASE_URL="postgresql://username:password@localhost:5432/turbo_asset"

# Server
PORT=3000
NODE_ENV=development

# Security
JWT_SECRET=your-jwt-secret-key
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Redis
REDIS_URL=redis://localhost:6379

# File Storage
STORAGE_TYPE=local # local, s3, azure, gcp
AWS_S3_BUCKET=turbo-asset-files
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# External APIs
CURRENCY_API_KEY=your-currency-api-key
SAP_API_URL=https://your-sap-instance.com/api
SAP_API_KEY=your-sap-api-key
ORACLE_API_URL=https://your-oracle-instance.com/api
ORACLE_API_KEY=your-oracle-api-key
WORKDAY_API_URL=https://your-workday-instance.com/api
WORKDAY_API_KEY=your-workday-api-key
SERVICENOW_API_URL=https://your-servicenow-instance.service-now.com/api
SERVICENOW_API_KEY=your-servicenow-api-key

# Logging
LOG_LEVEL=info
LOG_FILE=logs/turbo-asset.log

# Email
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-password

# Default Language & Currency
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD
DEFAULT_TIMEZONE=America/New_York